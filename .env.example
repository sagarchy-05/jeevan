# Copy to `.env` (gitignored) before running docker compose: `cp .env.example .env`
# docker compose reads .env from this directory for ${VAR} substitution.

# ── Postgres ─────────────────────────────────────────────────────────────
POSTGRES_DB=jeevan
POSTGRES_USER=jeevan
POSTGRES_PASSWORD=jeevan
# Host/port the core uses to reach Postgres (service name on the compose network)
DB_HOST=postgres
DB_PORT=5432

# ── RabbitMQ ─────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=jeevan
RABBITMQ_DEFAULT_PASS=jeevan
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
# Broker topology — MUST match exactly on core + worker
RABBITMQ_EXCHANGE=jeevan.appointments
RABBITMQ_NOTIFIER_QUEUE=notifier.appointment-events
RABBITMQ_CORE_QUEUE=core.notification-events
RK_APPOINTMENT_BOOKED=appointment.booked
RK_APPOINTMENT_CANCELLED=appointment.cancelled
RK_NOTIFICATION_SENT=notification.sent
RK_VERIFICATION_REQUESTED=verification.requested

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-256-bits-long-0123456789
JWT_EXPIRY_MINUTES=120

# ── Clinic / booking rules ───────────────────────────────────────────────
CLINIC_TIMEZONE=Asia/Kolkata
SLOT_LENGTH_MINUTES=30
BOOKING_WINDOW_DAYS=30

# ── Email / MailHog ──────────────────────────────────────────────────────
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=no-reply@jeevan.local
# Notifier: log-only by default; flip to true to actually send via MailHog
NOTIFIER_EMAIL_ENABLED=false
# Core: email verification gate (only meaningful on the real-email path)
EMAIL_VERIFICATION_ENABLED=false
EMAIL_VERIFICATION_TTL_HOURS=24

# ── Frontend ─────────────────────────────────────────────────────────────
# Base URL the browser uses to reach the core API
VITE_API_BASE_URL=http://localhost:8080/api
# Public base URL of the frontend (core uses this to build verification links)
FRONTEND_BASE_URL=http://localhost:5173
